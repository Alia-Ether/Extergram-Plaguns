__id__ = "hide_system_bars"
__name__ = "Hide System Bars"
__author__ = "@NEBULASoftware @FrontendVSCode"
__version__ = "4.12.15"
__description__ = """Скрывает верхний статус-бар и нижнюю навигационную панель"""

__icon__ = "Exsta_gols/2"
__min_version__ = "11.12.0"

from base_plugin import BasePlugin
from client_utils import get_last_fragment
from ui.settings import Header, Switch, Divider
from ui.bulletin import BulletinHelper
from java import dynamic_proxy
from java.lang import Runnable
from android.os import Build, Handler, Looper

# --- Константы для старых Android ---
SYSTEM_UI_FLAG_FULLSCREEN = 0x00000004
SYSTEM_UI_FLAG_HIDE_NAVIGATION = 0x00000002
SYSTEM_UI_FLAG_IMMERSIVE_STICKY = 0x00001000
SYSTEM_UI_FLAG_LAYOUT_STABLE = 0x00000100
SYSTEM_UI_FLAG_LAYOUT_HIDE_NAVIGATION = 0x00000200
SYSTEM_UI_FLAG_LAYOUT_FULLSCREEN = 0x00000400

# --- Константы для WindowInsetsController (Android 11+) ---
BEHAVIOR_SHOW_TRANSIENT_BARS_BY_SWIPE = 1
BEHAVIOR_DEFAULT = 0

# --- Прозрачный цвет ---
COLOR_TRANSPARENT = 0x00000000
COLOR_BLACK = 0xFF000000

class HideSystemBarsPlugin(BasePlugin):
    """
    Плагин для скрытия системных панелей с поддержкой Android 7-14+
    """
    def __init__(self):
        super().__init__()
        self.log("⊕ HideSystemBarsPlugin инициализирован")
        self._is_android_11_plus = Build.VERSION.SDK_INT >= 30
        self._handler = Handler(Looper.getMainLooper())

    def create_settings(self):
        """Создание настроек плагина"""
        self.log("☰ Создание настроек")
        return [
            Header("Скрытие системных панелей"),
            Switch(
                key="enabled",
                text="Включить скрытие",
                subtext="Скрывает статус-бар и навигацию",
                default=True,
                icon="msg_palette",
                on_change=self.on_setting_change
            ),
            Switch(
                key="hide_status",
                text="Скрыть статус-бар",
                subtext="Скрывает верхнюю панель (батарея, время, интернет)",
                default=True,
                icon="msg_palette",
                on_change=self.on_setting_change
            ),
            Switch(
                key="hide_nav",
                text="Скрыть навигацию",
                subtext="Скрывает нижние кнопки (Назад, Домой, Свернуть)",
                default=True,
                icon="msg_palette",
                on_change=self.on_setting_change
            ),
            Switch(
                key="transparent_bars",
                text="Прозрачные панели",
                subtext="Делает панели прозрачными",
                default=True,
                icon="msg_palette",
                on_change=self.on_setting_change
            ),
            Divider("Для выхода используйте свайп от края экрана"),
        ]

    def on_setting_change(self, value):
        """Обработчик изменения настроек"""
        self.log(f"⊕ Настройка изменена")
        self.apply_to_current()

    def get_activity(self):
        """Получает текущую Activity"""
        try:
            fragment = get_last_fragment()
            if fragment:
                return fragment.getParentActivity()
        except Exception as e:
            self.log(f"⊗ Ошибка получения Activity: {e}")
        return None

    def apply_to_current(self):
        """Применяет настройки к текущей активности в UI потоке"""
        activity = self.get_activity()
        if not activity:
            self.log("⊗ Activity не найдена")
            return

        # Запускаем в UI потоке через dynamic_proxy
        class ApplyRunnable(dynamic_proxy(Runnable)):
            def __init__(self, plugin, act):
                super().__init__()
                self.plugin = plugin
                self.activity = act
                
            def run(self):
                self.plugin.apply_hide_mode(self.activity)
        
        activity.runOnUiThread(ApplyRunnable(self, activity))

    def build_flags_legacy(self):
        """Собирает флаги для старых Android (7-10)"""
        flags = 0
        
        if self.get_setting("enabled", True):
            if self.get_setting("hide_status", True):
                flags |= SYSTEM_UI_FLAG_FULLSCREEN
                flags |= SYSTEM_UI_FLAG_LAYOUT_STABLE
                flags |= SYSTEM_UI_FLAG_LAYOUT_FULLSCREEN
                
            if self.get_setting("hide_nav", True):
                flags |= SYSTEM_UI_FLAG_HIDE_NAVIGATION
                flags |= SYSTEM_UI_FLAG_LAYOUT_HIDE_NAVIGATION
                
            # Всегда добавляем липкий режим
            flags |= SYSTEM_UI_FLAG_IMMERSIVE_STICKY
            
        return flags

    def apply_hide_mode(self, activity):
        """Применяет режим скрытия к активности (вызывается в UI потоке)"""
        self.log("◌ Применение режима скрытия")
        
        if not activity:
            self.log("⊗ Activity не найдена")
            return
            
        try:
            # Проверяем включен ли плагин
            if not self.get_setting("enabled", True):
                self.log("⊕ Плагин отключен в настройках")
                self.revert_hide_mode(activity)
                return
                
            window = activity.getWindow()
            if not window:
                self.log("⊗ Window не найдена")
                return
                
            decor_view = window.getDecorView()
            if not decor_view:
                self.log("⊗ DecorView не найден")
                return

            # Используем новый API для Android 11+
            if self._is_android_11_plus:
                self.apply_hide_mode_modern(activity, window, decor_view)
            else:
                self.apply_hide_mode_legacy(activity, window, decor_view)
                
            self.log("⊕ Режим скрытия применен")
            BulletinHelper.show_success("Панели скрыты! ✆")
                
        except Exception as e:
            self.log(f"⊕ Ошибка применения режима: {e}")

    def apply_hide_mode_modern(self, activity, window, decor_view):
        """Применяет режим скрытия через WindowInsetsController (Android 11+)"""
        try:
            # Получаем WindowInsetsController
            controller = decor_view.getWindowInsetsController()
            if not controller:
                self.log("⊗ WindowInsetsController не найден, используем старый метод")
                self.apply_hide_mode_legacy(activity, window, decor_view)
                return

            hide_status = self.get_setting("hide_status", True)
            hide_nav = self.get_setting("hide_nav", True)
            transparent = self.get_setting("transparent_bars", True)

            # Скрываем системные панели
            if hide_status:
                controller.hide(WindowInsetsController.BARS_TYPE_STATUS_BARS)
            if hide_nav:
                controller.hide(WindowInsetsController.BARS_TYPE_NAVIGATION_BARS)
            
            # Устанавливаем поведение (показывать по свайпу)
            behavior = BEHAVIOR_SHOW_TRANSIENT_BARS_BY_SWIPE if (hide_status or hide_nav) else BEHAVIOR_DEFAULT
            controller.setSystemBarsBehavior(behavior)

            # Прозрачные панели
            if transparent:
                window.setStatusBarColor(COLOR_TRANSPARENT)
                window.setNavigationBarColor(COLOR_TRANSPARENT)
                window.setDecorFitsSystemWindows(False)
                
            self.log(f"  ✆ Modern API: status={hide_status}, nav={hide_nav}")

        except Exception as e:
            self.log(f"⊗ Modern API failed: {e}, используем старый метод")
            self.apply_hide_mode_legacy(activity, window, decor_view)

    def apply_hide_mode_legacy(self, activity, window, decor_view):
        """Применяет режим скрытия через старые флаги (Android 7-10)"""
        try:
            flags = self.build_flags_legacy()
            
            if flags != 0:
                decor_view.setSystemUiVisibility(flags)
                
                # Прозрачные панели
                if self.get_setting("transparent_bars", True):
                    window.setStatusBarColor(COLOR_TRANSPARENT)
                    window.setNavigationBarColor(COLOR_TRANSPARENT)
                    self.log("  ⎙ Панели прозрачные")
                        
                self.log(f"  ✆ Legacy flags: {hex(flags)}")
            else:
                self.log("⊗ Нет флагов для применения")
                
        except Exception as e:
            self.log(f"⊗ Legacy method failed: {e}")

    def revert_hide_mode(self, activity):
        """Отменяет скрытие панелей (вызывается в UI потоке)"""
        self.log("◌ Отмена режима скрытия")
        
        if not activity:
            return
            
        try:
            window = activity.getWindow()
            if not window:
                return
                
            decor_view = window.getDecorView()
            if not decor_view:
                return

            # Восстанавливаем для Android 11+
            if self._is_android_11_plus:
                try:
                    controller = decor_view.getWindowInsetsController()
                    if controller:
                        controller.show(WindowInsetsController.BARS_TYPE_STATUS_BARS)
                        controller.show(WindowInsetsController.BARS_TYPE_NAVIGATION_BARS)
                        controller.setSystemBarsBehavior(BEHAVIOR_DEFAULT)
                except:
                    pass

            # Убираем все флаги
            flags = decor_view.getSystemUiVisibility()
            flags &= ~SYSTEM_UI_FLAG_FULLSCREEN
            flags &= ~SYSTEM_UI_FLAG_HIDE_NAVIGATION
            flags &= ~SYSTEM_UI_FLAG_IMMERSIVE_STICKY
            flags &= ~SYSTEM_UI_FLAG_LAYOUT_STABLE
            flags &= ~SYSTEM_UI_FLAG_LAYOUT_HIDE_NAVIGATION
            flags &= ~SYSTEM_UI_FLAG_LAYOUT_FULLSCREEN
            decor_view.setSystemUiVisibility(flags)
            
            # Восстанавливаем цвета
            window.setStatusBarColor(COLOR_BLACK)
            window.setNavigationBarColor(COLOR_BLACK)
                
            self.log("⊕ Панели восстановлены")
                    
        except Exception as e:
            self.log(f"⊗ Ошибка отмены режима: {e}")

    def on_plugin_load(self):
        """Загрузка плагина"""
        self.log(f"⎙ Hide System Bars загружается! Android API: {Build.VERSION.SDK_INT}")
        
        # Применяем с задержкой для инициализации UI
        class LoadRunnable(dynamic_proxy(Runnable)):
            def __init__(self, plugin):
                super().__init__()
                self.plugin = plugin
                
            def run(self):
                self.plugin.apply_to_current()
        
        self._handler.postDelayed(LoadRunnable(self), 500)

    def on_plugin_unload(self):
        """Выгрузка плагина"""
        self.log("◌ Выгрузка Hide System Bars...")
        
        # Восстанавливаем панели в UI потоке
        class UnloadRunnable(dynamic_proxy(Runnable)):
            def __init__(self, plugin):
                super().__init__()
                self.plugin = plugin
                
            def run(self):
                activity = self.plugin.get_activity()
                if activity:
                    self.plugin.revert_hide_mode(activity)
                    self.plugin.log("⊕ Панели восстановлены при выгрузке")
        
        self._handler.post(UnloadRunnable(self))